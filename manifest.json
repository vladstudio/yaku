{
  "manifest_version": 3,
  "name": "Yaku — Page Translator",
  "version": "0.2.1",
  "description": "Translate web pages using Google Cloud Translation API. Bring your own API key.",
  "homepage_url": "https://yaku.vlad.studio",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["translator.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://translation.googleapis.com/*"]
}
